# ============================================
# LiangClaw 環境變數設定
# 複製此檔為 .env 並填入你的 API 金鑰
# ============================================

# --- AI 模型 API 金鑰 ---
# Gemini (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key

# Groq (免費, https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key

# DeepSeek (便宜, https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Qwen / 通義千問 (https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=your_dashscope_api_key

# OpenRouter (50+ 模型聚合, https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key

# Mistral (https://console.mistral.ai/api-keys)
MISTRAL_API_KEY=your_mistral_api_key

# MiniMax (多模態, https://www.minimaxi.com/)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# Ollama (本地免費, https://ollama.com/)
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- LINE Bot ---
# LINE Developers Console: https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# --- Telegram Bot ---
# 透過 @BotFather 取得: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
